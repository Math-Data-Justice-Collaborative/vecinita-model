# Copy this file to .env and fill in values for local development.
# The production values are managed as Modal secrets.

# Modal token values for local CLI auth when needed.
# For CI, configure these as GitHub Actions secrets instead.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Ollama server URL (used when running locally or overriding in tests)
OLLAMA_HOST=http://localhost:11434

# Path where Ollama stores model weights inside the container
MODELS_PATH=/models

# Default model to serve when none is specified in the request
DEFAULT_MODEL=gemma3
